{
  "manifest_version": 3,
  "name": "NaviWrite - 네이버 SEO·GEO·AEO 최적화",
  "description": "네이버 블로그/카페 콘텐츠를 SEO·GEO·AEO에 최적화하여 생성하는 크롬 확장프로그램",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "alarms",
    "notifications",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://blog.naver.com/*",
    "https://cafe.naver.com/*",
    "https://m.blog.naver.com/*",
    "https://m.cafe.naver.com/*",
    "https://qr.naver.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://blog.naver.com/*", "https://cafe.naver.com/*"],
      "js": ["src/content/naver-extractor.ts"]
    },
    {
      "matches": ["https://qr.naver.com/*"],
      "js": ["src/content/naver-qr-helper.ts"]
    }
  ],
  "action": {
    "default_title": "NaviWrite 열기"
  }
}
